{
  "extends": "@packages/config/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "collections/*": ["./.source/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "next-env.d.ts"
  ],
  "// exclude tests": "Unit tests run under `bun test` (bun:test types), not the Next/node app build. Keep them out of `tsc --noEmit` so the app typecheck doesn't need bun-types.",
  "exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "**/*.test.mts"]
}
