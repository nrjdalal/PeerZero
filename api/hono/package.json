{
  "name": "@api/hono",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": "./dist/index.mjs",
  "scripts": {
    "build": "tsdown && bun build dist/index.mjs --outfile bundle/index.mjs --target bun --minify",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "dev": "portless",
    "dev:app": "concurrently \"tsdown --watch\" \"bun ../../.github/scripts/portless.ts bun --hot src/index.ts\"",
    "start": "bun bundle/index.mjs"
  },
  "dependencies": {
    "@arcjet/ip": "catalog:",
    "@hono/node-server": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@packages/config": "workspace:*",
    "@packages/env": "workspace:*",
    "@scalar/hono-api-reference": "catalog:",
    "hono": "catalog:",
    "hono-openapi": "catalog:",
    "hono-rate-limiter": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "concurrently": "catalog:",
    "portless": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "portless": {
    "name": "api.peerzero",
    "script": "dev:app",
    "appPort": 9336
  }
}
