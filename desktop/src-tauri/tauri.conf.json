{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PeerZero",
  "version": "0.1.0",
  "identifier": "com.peerzero.desktop",
  "build": {
    "frontendDist": "../../web/next/out",
    "devUrl": "http://localhost:47821"
  },
  "app": {
    "windows": [
      {
        "title": "PeerZero",
        "width": 1180,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/peerzero-backend"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
