# Generated by Cargo
# will have compiled files and executables
/target/
# Tauri-generated (schemas, and mobile scaffolding the icon step emits)
/gen
# Tauri-generated permission files (build.rs emits these from the command manifest)
/permissions/autogenerated
# Prebuilt libmpv closure - produced by prebuild-libmpv.sh / downloaded by fetch-libmpv.sh, pinned by
# desktop/libmpv.lock.json (which IS committed). Not vendored in git.
/vendor
# Tauri frameworks config for the vendored closure, regenerated by fetch-libmpv.sh.
/libmpv.frameworks.json
