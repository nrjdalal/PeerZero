{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "remote": { "urls": ["http://127.0.0.1:*"] },
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "opener:allow-default-urls",
    "opener:allow-open-url",
    "updater:default",
    "process:default"
  ]
}
